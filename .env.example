# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# Django core
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=*.up.railway.app,yourcustomdomain.com

# Database — Railway provisions DATABASE_URL automatically when you add a Postgres
# plugin. For local development, leave unset to fall back to SQLite.
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Firm config — path to your YAML inside the deployed bundle. Default works on Railway.
FIRM_CONFIG_PATH=/app/config.yaml

# Email — Enquiry notifications
ADMIN_EMAIL=admin@yourfirm.com
DEFAULT_FROM_EMAIL=admin@yourfirm.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
